dataset_path: mozilla-foundation/common_voice_17_0
dataset_kwargs:
  language: ja
  token: True
  trust_remote_code: True
doc_to_target: "sentence"
doc_to_visual: !function utils.common_voice_ja_doc_to_audio
doc_to_text: !function utils.common_voice_ja_doc_to_text
output_type: generate_until
generation_kwargs:
  max_new_tokens: 256
  temperature: 0
  do_sample: false
process_results: !function utils.common_voice_ja_process_results
metric_list:
  - metric: cer
    aggregation: !function utils.common_voice_ja_cer
    higher_is_better: false
  - metric: wer
    aggregation: !function utils.common_voice_ja_wer
    higher_is_better: false
metadata:
  - version: 0.0
lmms_eval_specific_kwargs:
  default:
    pre_prompt: ""
    post_prompt: ""
  qwen3_omni:
